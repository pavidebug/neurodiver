rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'pavi2024ns@gmail.com';
    }

    // Public app configuration for authenticated users; only admin can change modules.
    match /appConfig/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Global strategy catalog — read-only for signed-in users
    match /strategies/{strategyId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User profile (includes workProfile for pilot roles + reminder prefs)
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;

      // Work Energy Check-ins — one document per date (YYYY-MM-DD)
      match /workCheckIns/{checkInId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Cached weekly insight reports
      match /weeklyReports/{weekId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Weekly reflection reviews
      match /weeklyReflections/{weekId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Share stats — shareCount incremented when user shares invites
      match /stats/{statId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.shareCount is int
          && request.resource.data.shareCount == 1;
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.shareCount is int
          && request.resource.data.shareCount == resource.data.shareCount + 1;
        allow delete: if false;
      }
    }

    // Strategy search analytics — users can create their own search events
    match /searchAnalytics/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.searchTerm is string
        && request.resource.data.resultsFound is int;
      allow read, update, delete: if false;
    }

    // User-submitted strategy requests when search finds no match
    match /strategyRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.description is string
        && request.resource.data.status == 'Open';
      allow read, update, delete: if false;
    }

    // Free-text describe-it submissions and follow-up preferences
    match /freeTextRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.description is string
        && request.resource.data.status == 'Pending';
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.notifyWhenAvailable is bool;
      allow read, delete: if false;
    }

    // Body Doubling pilot — manually seeded sessions
    match /focusSessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /sessionBookings/{bookingId} {
      // Signed-in users can read bookings for capacity counts and their own reservations.
      // Individual notes are not stored here; only session attendance metadata.
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sessionId is string
        && (request.resource.data.intention is string || request.resource.data.intention == null)
        && request.resource.data.attendanceStatus == 'booked'
        && (request.resource.data.contactEmail is string || request.resource.data.contactEmail == null)
        && (request.resource.data.reminderEnabled is bool || request.resource.data.reminderEnabled == null);
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.attendanceStatus == 'attended'
        && resource.data.attendanceStatus == 'booked';
      allow delete: if false;
    }

    match /sessionFeedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sessionId is string
        && request.resource.data.bookingId is string
        && request.resource.data.sessionHelpful in ['yes', 'somewhat', 'not-today']
        && request.resource.data.completedPlan in ['yes', 'mostly', 'not-today']
        && request.resource.data.wouldJoinAgain is int
        && request.resource.data.wouldJoinAgain >= 1
        && request.resource.data.wouldJoinAgain <= 5
        && (request.resource.data.notes is string || request.resource.data.notes == null);
      allow read, update, delete: if false;
    }

    // Email delivery audit log — written by Cloud Functions only
    match /sessionEmailLog/{logId} {
      allow read, write: if false;
    }

    // Invite share analytics — logged-in (non-guest) users only
    match /shareEvents/{eventId} {
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.shareType in ['copy', 'whatsapp', 'web_share']
        && request.resource.data.templateId in ['soft_invite', 'body_doubling', 'check_in', 'general']
        && request.resource.data.sourceScreen in ['profile', 'body_double']
        && request.resource.data.isGuest == false
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false;
    }

    // Physical Focus Together sessions — email waitlist (one entry per user)
    match /physicalSessionWaitlist/{userId} {
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 320
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.source == 'physical_sessions';
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 320
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.source == 'physical_sessions';
      allow read: if isAdmin();
      allow delete: if false;
    }

    // Body Double updates — guests use Firebase anonymous auth, so no account is required.
    match /bodyDoubleInterest/{userId} {
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 320
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.isGuest is bool
        && request.resource.data.source == 'body_double';
      allow read: if isAdmin();
      allow delete: if false;
    }

    // Product analytics — users create their own events; admin reads for dashboard
    match /analyticsEvents/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventType in [
          'user_signed_up',
          'completed_onboarding',
          'completed_check_in',
          'opened_strategy_card',
          'saved_strategy',
          'started_body_doubling',
          'submitted_feedback',
          'strategy_timer_started',
          'strategy_timer_paused',
          'strategy_timer_resumed',
          'strategy_timer_finished',
          'strategy_timer_cancelled'
        ]
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
